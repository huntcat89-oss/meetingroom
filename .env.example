# 플로우 API 키 (https://flow.team → 계정 → API 키 발급)
FLOW_API_KEY=여기에_발급받은_키

# 실행 포트 (선택)
PORT=5173

# --- 아래는 보통 손댈 필요 없음 ---
# 플로우 API 베이스 URL (개인용 user API)
FLOW_BASE_URL=https://api.flow.team/user
# 타임존 / GMT 표기
FLOW_TIMEZONE=Asia/Seoul
FLOW_GMT=GMT+09:00

# 인증 헤더를 직접 고정하고 싶을 때만 지정(기본은 서버가 자동 탐지)
# FLOW_AUTH_HEADER=Authorization
# FLOW_AUTH_PREFIX=Bearer
